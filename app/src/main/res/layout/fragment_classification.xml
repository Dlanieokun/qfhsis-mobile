<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/classificationScrollView"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA">

    <LinearLayout
        android:id="@+id/classificationContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Classification by Age/Health Risk Group"
            android:textColor="#1F2937"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center_horizontal"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvClassificationMemberName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Member: Loading..."
            android:textColor="#2563EB"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center_horizontal"
            android:layout_marginBottom="16dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Classification Acronym Key Matrix"
                    android:textColor="#4B5563"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp"/>

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:alignmentMode="alignBounds">

                    <TextView android:text="N - Newborn" android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                    <TextView android:text="P - Pregnant" android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                    <TextView android:text="AB - Adult &gt; 25 y.o." android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                    <TextView android:text="AP - Adolescent Pregnant" android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                    <TextView android:text="SC - Senior Citizen" android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                    <TextView android:text="PP - Postpartum" android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                    <TextView android:text="WRA - Women with Rep Age" android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                    <TextView android:text="I - Infant" android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                    <TextView android:text="S - School Age (0-5 y.o.)" android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                    <TextView android:text="U - Under 5 y.o." android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                    <TextView android:text="A - Adolescent (10-19 y.o.)" android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                    <TextView android:text="PWD - Person with Disability" android:textSize="11sp" android:textColor="#6B7280" android:layout_columnWeight="1"/>
                </GridLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1st Quarter"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etQ1Age"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Age"
                    android:inputType="number"
                    android:textSize="14sp"
                    android:background="@android:drawable/editbox_background"/>

                <Spinner
                    android:id="@+id/spinnerQ1Class"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="2nd Quarter"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etQ2Age"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Age"
                    android:inputType="number"
                    android:textSize="14sp"
                    android:background="@android:drawable/editbox_background"/>

                <Spinner
                    android:id="@+id/spinnerQ2Class"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="3rd Quarter"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etQ3Age"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Age"
                    android:inputType="number"
                    android:textSize="14sp"
                    android:background="@android:drawable/editbox_background"/>

                <Spinner
                    android:id="@+id/spinnerQ3Class"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingStart="6dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="4th Quarter"
                    android:textStyle="bold"
                    android:textColor="#374151"
                    android:layout_marginBottom="4dp"/>

                <EditText
                    android:id="@+id/etQ4Age"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Age"
                    android:inputType="number"
                    android:textSize="14sp"
                    android:background="@android:drawable/editbox_background"/>

                <Spinner
                    android:id="@+id/spinnerQ4Class"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnSaveClassification"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Health Risk Metrics"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2563EB"
            android:textStyle="bold"
            app:cornerRadius="8dp"/>

    </LinearLayout>
</ScrollView>