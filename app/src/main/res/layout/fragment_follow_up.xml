<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F3F4F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Client Header Summary Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#E0F2FE">

                <TextView
                    android:id="@+id/tvFollowUpClientName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading Client Name..."
                    android:textColor="#0369A1"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFollowUpSubDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="FHSIS Family Planning Follow-up Monitoring"
                    android:textColor="#0284C7"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Form Matrix Instructions Card -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FOLLOW-UP VISITS\n(Upper Space: Schedule Date of next visit / Lower Space: Actual Date of Visit)"
            android:textAlignment="center"
            android:textColor="#374151"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"/>

        <!-- Container holding months row configurations -->
        <LinearLayout
            android:id="@+id/monthsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <!-- Programmatically inflated or manually declared structured month grids go here -->
        </LinearLayout>

        <!-- Submit Button -->
        <Button
            android:id="@+id/btnSaveFollowUp"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:text="Save Follow-Up Tracking Data"
            android:textColor="#FFFFFF"
            android:backgroundTint="#16A34A"
            android:textStyle="bold"
            app:cornerRadius="8dp"/>

    </LinearLayout>
</ScrollView>