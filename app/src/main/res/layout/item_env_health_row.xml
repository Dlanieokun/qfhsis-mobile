<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    app:cardCornerRadius="6dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">

        <!-- Row Number Badge -->
        <TextView
            android:id="@+id/tv_row_no"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:background="@drawable/circle_blue"
            android:text="1"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="13sp" />

        <!-- Name + Status info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="10dp">

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Household Head Name"
                android:textColor="#212121"
                android:textStyle="bold"
                android:textSize="13sp"
                android:singleLine="true"
                android:ellipsize="end" />

            <!-- Water source row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Water: "
                    android:textColor="#888888"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tv_water_source"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="—"
                    android:textColor="#1565C0"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Status chips row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/tv_smdws"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SMDWS: N/A"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/chip_gray"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:layout_marginEnd="4dp" />

                <TextView
                    android:id="@+id/tv_smss"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SMSS: N/A"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/chip_gray"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Edit / Delete actions -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btn_edit"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_edit"
                android:contentDescription="Edit entry"
                android:tint="#1565C0" />

            <ImageButton
                android:id="@+id/btn_delete"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginTop="2dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:contentDescription="Delete entry"
                android:tint="#C62828" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>