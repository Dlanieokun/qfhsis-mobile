<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Client Full Name -->
        <TextView
            android:id="@+id/tvItemClientName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@id/btnItemPhilPENEdit"
            android:layout_marginEnd="8dp"
            android:text="Patient Full Name"
            android:textColor="@android:color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Family Serial Number Mapping -->
        <TextView
            android:id="@+id/tvItemSerial"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvItemClientName"
            android:layout_toStartOf="@id/btnItemPhilPENEdit"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:text="Serial No: --"
            android:textColor="@android:color/darker_gray"
            android:textSize="13sp" />

        <!-- Complete Address Text View -->
        <TextView
            android:id="@+id/tvItemAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvItemSerial"
            android:layout_toStartOf="@id/btnItemPhilPENEdit"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="8dp"
            android:text="No Address Listed"
            android:textColor="@android:color/tab_indicator_text"
            android:textSize="14sp" />

        <!-- Compiled Metadata (Age, Sex, Registration Date) -->
        <TextView
            android:id="@+id/tvItemMetaDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvItemAddress"
            android:layout_toStartOf="@id/btnItemPhilPENEdit"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:text="Age: -- | Sex: -- | Reg Date: --"
            android:textColor="@android:color/holo_blue_dark"
            android:textSize="12sp"
            android:textStyle="italic" />

        <!-- Action Route Trigger Modification Button -->
        <Button
            android:id="@+id/btnItemPhilPENEdit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:minWidth="72dp"
            android:text="Edit"
            style="?android:attr/buttonStyleSmall" />

    </RelativeLayout>
</androidx.cardview.widget.CardView>