<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F9FAFB">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Client Header Summary Info Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FEF2F2">

                <TextView
                    android:id="@+id/tvDropOutClientName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Loading Client Name..."
                    android:textColor="#991B1B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="FHSIS Family Planning Drop-Out Record Monitoring"
                    android:textColor="#DC2626"
                    android:textSize="12sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Main Form Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Date Input Column Field -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date of Drop-Out (mm/dd/yy)"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etDropOutDate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Select Date"
                    android:focusable="false"
                    android:clickable="true"
                    android:paddingHorizontal="12dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:layout_marginBottom="16dp"/>

                <!-- Reason Selection Code Dropdown Field -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Reason for Drop-Out"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="6dp"/>

                <Spinner
                    android:id="@+id/spinnerDropOutReason"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@android:drawable/btn_dropdown"
                    android:layout_marginBottom="16dp"/>

                <!-- Remarks and Actions Column Area -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Remarks / Actions Taken"
                    android:textColor="#374151"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/etDropOutRemarks"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:hint="Type details of remarks or interventions conducted..."
                    android:gravity="top|start"
                    android:inputType="textMultiLine"
                    android:padding="12dp"
                    android:background="@android:drawable/editbox_background_normal"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Form Submission Button Action -->
        <Button
            android:id="@+id/btnSaveDropOut"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="20dp"
            android:text="Save Drop-Out Status"
            android:textColor="#FFFFFF"
            android:backgroundTint="#DC2626"
            android:textStyle="bold"
            app:cornerRadius="8dp"/>

    </LinearLayout>
</ScrollView>