<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Block -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PhilPEN Risk Assessment"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1565C0"
            android:gravity="center"
            android:paddingBottom="2dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target Client List Form Tracker"
            android:textSize="13sp"
            android:textColor="#666666"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- ─────────────────────────────────────────── -->
        <!--  SECTION 1: CLIENT INFORMATION              -->
        <!-- ─────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CLIENT INFORMATION"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#1565C0"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- Row 1: Assessment Date + Serial Number -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:baselineAligned="false">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDateAssessment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Date of Assessment (YYYY-MM-DD)"
                        app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/etDateAssessment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="date"
                            android:maxLength="10" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Family Serial Number"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/etFamilySerialNumber"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:clickable="false"
                            android:cursorVisible="false"
                            android:inputType="text" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Row 2: Full Name -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilName"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:hint="Name (LastName, FirstName, MI)">

                    <AutoCompleteTextView
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:completionThreshold="1"
                        android:inputType="textPersonName|textCapWords"
                        android:textColor="#1F2937" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Row 3: Complete Address -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:hint="Complete Address"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <EditText
                        android:id="@+id/etAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:focusable="false"
                        android:focusableInTouchMode="false"
                        android:clickable="false"
                        android:cursorVisible="false"
                        android:minLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Row 4: Date of Birth + Age -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:baselineAligned="false">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilDateOfBirth"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Date of Birth (YYYY-MM-DD)"
                        app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/etDateOfBirth"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="date"
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:clickable="false"
                            android:cursorVisible="false"
                            android:maxLength="10" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Age (Years)"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/etAge"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <!-- Row 5: Age Group & Sex Split Grid -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Age Group Assignment" android:textSize="11sp" android:textColor="#555555" android:layout_marginBottom="2dp"/>
                        <Spinner android:id="@+id/spinnerAgeGroup" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Sex" android:textSize="11sp" android:textColor="#555555"/>
                        <RadioGroup android:id="@+id/rgSex" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal">
                            <RadioButton android:id="@+id/rbMale" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M" android:layout_marginEnd="8dp"/>
                            <RadioButton android:id="@+id/rbFemale" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="F"/>
                        </RadioGroup>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!--  SECTION 2: RISK FACTOR ASSESSMENT          -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="RISK FACTOR ASSESSMENT"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#1565C0"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Current Tobacco / Nicotine User" android:textSize="13sp" android:textStyle="bold" android:textColor="#1565C0"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Smoked at least once during the past 12 months." android:textSize="11sp" android:textColor="#666666" android:layout_marginBottom="4dp"/>
                <Spinner android:id="@+id/spinnerCurrentSmoker" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Brief Tobacco Intervention (5A's Metrics)" android:textSize="12sp" android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="6dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#F9F9F9" android:padding="8dp" android:layout_marginBottom="10dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="1. Ask Status" android:textSize="12sp"/>
                        <Spinner android:id="@+id/spinnerAsk" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="2. Advise to Quit" android:textSize="12sp"/>
                        <Spinner android:id="@+id/spinnerAdvise" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="3. Assess Willingness" android:textSize="12sp"/>
                        <Spinner android:id="@+id/spinnerAssess" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="4. Assist in Plan" android:textSize="12sp"/>
                        <Spinner android:id="@+id/spinnerAssist" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1.2" android:text="5. Arrange Follow-up" android:textSize="12sp"/>
                        <Spinner android:id="@+id/spinnerArrange" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="BTI Intervention Executed?" android:textSize="11sp" android:textColor="#555555" android:layout_marginBottom="2dp"/>
                <Spinner android:id="@+id/spinnerProvidedBTI" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Lifestyle &amp; Anthropometric Metrics" android:textSize="13sp" android:textStyle="bold" android:textColor="#1565C0" android:layout_marginBottom="6dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Binge Alcohol" android:textSize="11sp" android:textColor="#555555" android:layout_marginBottom="2dp"/>
                        <Spinner android:id="@+id/spinnerBingeAlcohol" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Insufficient Phys. Act." android:textSize="11sp" android:textColor="#555555" android:layout_marginBottom="2dp"/>
                        <Spinner android:id="@+id/spinnerInsufficientPA" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Unhealthy Diet Intake" android:textSize="11sp" android:textColor="#555555" android:layout_marginBottom="2dp"/>
                        <Spinner android:id="@+id/spinnerUnhealthyDiet" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Overweight/Obese (BMI)" android:textSize="11sp" android:textColor="#555555" android:layout_marginBottom="2dp"/>
                        <Spinner android:id="@+id/spinnerBMI" android:layout_width="match_parent" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!--  SECTION 3: HYPERTENSION SCREENING          -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HYPERTENSION SCREENING"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#1565C0"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Screening Tracking Schedule" android:textSize="13sp" android:textStyle="bold" android:textColor="#1565C0" android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp"
                    android:baselineAligned="false">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilScreeningDate1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:hint="Primary Date (YYYY-MM-DD)"
                        app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/etScreeningDate1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="date"
                            android:maxLength="10" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilScreeningDate2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Secondary Date (YYYY-MM-DD)"
                        app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                        <EditText
                            android:id="@+id/etScreeningDate2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="date"
                            android:maxLength="10" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Clinical Blood Pressure Logs" android:textSize="12sp" android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="4dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <EditText android:id="@+id/etBpSystolic1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Systolic 1" android:inputType="number" android:layout_marginEnd="8dp"/>
                    <EditText android:id="@+id/etBpDiastolic1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Diastolic 1" android:inputType="number"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                    <EditText android:id="@+id/etBpSystolic2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Systolic 2" android:inputType="number" android:layout_marginEnd="8dp"/>
                    <EditText android:id="@+id/etBpDiastolic2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Diastolic 2" android:inputType="number"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Screening Categorization Conclusion" android:textSize="11sp" android:textColor="#555555" android:layout_marginBottom="2dp"/>
                <Spinner android:id="@+id/spinnerHypertensionResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Prescribed Medications Monthly Target" android:textSize="12sp" android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="4dp"/>
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="16dp">
                    <EditText android:id="@+id/etMedsInitial" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Initial Req. Vol" android:inputType="number" android:layout_marginEnd="8dp"/>
                    <EditText android:id="@+id/etMedsChanged" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Adjusted Presc. Vol" android:inputType="number"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Antihypertensive Dispatch Log (Jan - Sep)" android:textSize="13sp" android:textStyle="bold" android:textColor="#1565C0" android:layout_marginBottom="8dp"/>

                <include layout="@layout/item_medication_month" android:id="@+id/rowJanuary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowFebruary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowMarch" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowApril" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowMay" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowJune" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowJuly" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowAugust" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowSeptember" android:layout_width="match_parent" android:layout_height="wrap_content"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!--  SECTION 4: TYPE 2 DIABETES MELLITUS SCREENING  -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TYPE 2 DIABETES MELLITUS SCREENING"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#1565C0"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Screening Categorization Conclusion" android:textSize="11sp" android:textColor="#555555" android:layout_marginBottom="2dp"/>
                <Spinner android:id="@+id/spinnerDiabetesResult" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Prescribed Antidiabetic Medications Monthly Target" android:textSize="12sp" android:textStyle="bold" android:textColor="#333333" android:layout_marginBottom="4dp"/>
                <EditText android:id="@+id/etAntidiabeticMeds" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Req. Vol" android:inputType="number" android:layout_marginBottom="16dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Antidiabetic Dispatch Log (Jan - Dec)" android:textSize="13sp" android:textStyle="bold" android:textColor="#1565C0" android:layout_marginBottom="8dp"/>

                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesJanuary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesFebruary" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesMarch" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesApril" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesMay" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesJune" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesJuly" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesAugust" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesSeptember" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesOctober" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesNovember" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>
                <include layout="@layout/item_medication_month" android:id="@+id/rowDiabetesDecember" android:layout_width="match_parent" android:layout_height="wrap_content"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!--  SECTION 5: REMARKS  -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="REMARKS"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#1565C0"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="2dp"
            app:cardCornerRadius="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <EditText
                    android:id="@+id/etRemarks"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Additional notes or observations"
                    android:inputType="textMultiLine"
                    android:minLines="3"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SAVE ASSESSMENT RECORD"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1565C0"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:padding="14dp"/>

    </LinearLayout>
</ScrollView>