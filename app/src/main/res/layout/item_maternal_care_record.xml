<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvItemPatientName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Patient Name"
                        android:textColor="#1F2937"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/btnItemEdit"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:background="?android:attr/selectableItemBackgroundBorderless"
                        android:contentDescription="Edit Record"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="#2563EB" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvItemAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home Address"
                    android:textColor="#4B5563"
                    android:textSize="13sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E5E7EB"
            android:layout_marginBottom="10dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/tvItemSerial"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Serial: ----"
                android:textColor="#374151"
                android:textSize="12sp"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvItemRegDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registered: --/--/----"
                android:textColor="#374151"
                android:textSize="12sp"
                android:layout_columnWeight="1"
                android:gravity="end"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvItemAge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Age: -- / --"
                android:textColor="#374151"
                android:textSize="12sp"
                android:layout_columnWeight="1"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvItemGP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Gravida/Para: G- P-"
                android:textColor="#374151"
                android:textSize="12sp"
                android:layout_columnWeight="1"
                android:gravity="end"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvItemLMP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LMP: --/--/----"
                android:textColor="#374151"
                android:textSize="12sp"
                android:layout_columnWeight="1"/>

            <TextView
                android:id="@+id/tvItemEDD"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="EDD: --/--/----"
                android:textColor="#374151"
                android:textSize="12sp"
                android:layout_columnWeight="1"
                android:gravity="end"/>
        </GridLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Metrics: "
                android:textColor="#6B7280"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/tvItemMetrics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0 kg / 0.0 cm"
                android:textColor="#1F2937"
                android:textSize="12sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutBmiBadge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F0FDF4"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BMI Score: "
                android:textColor="#16A34A"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvItemBmiValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.0"
                android:textColor="#111827"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp"/>

            <TextView
                android:id="@+id/tvItemBmiStatus"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Awaiting Inputs"
                android:gravity="end"
                android:textColor="#16A34A"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnItemPrenatal"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:backgroundTint="#2563EB"
                android:text="Prenatal"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnItemIntrapartum"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:backgroundTint="#0EA5E9"
                android:text="Intrapartum"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnItemPostpartum"
                android:layout_width="0dp"
                android:layout_height="42dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:backgroundTint="#7C3AED"
                android:text="Postpartum"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:cornerRadius="6dp" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>