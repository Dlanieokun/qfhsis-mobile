<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:id="@+id/tvFormTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Schistosomiasis Registry"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center" />

        <!-- Date of Registration -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDateOfRegistration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Date of Registration (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDateOfRegistration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Family Serial Number -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Family Serial Number"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etFamilySerialNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Enter family serial number"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:cursorVisible="false"
            android:inputType="text" />

        <!-- Patient Full Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Name (LastName, FullName, MI)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
            <AutoCompleteTextView
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Complete Address -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Complete Address"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Enter complete address"
            android:inputType="textPostalAddress|textMultiLine"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:cursorVisible="false"
            android:minLines="2" />

        <!-- Resident / Non-Resident -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Residency"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgResidency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbResident"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Resident" />

            <RadioButton
                android:id="@+id/rbNonResident"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2 - Non-Resident" />
        </RadioGroup>

        <!-- Date of Birth -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDateOfBirth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Date of Birth (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDateOfBirth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:clickable="false"
                android:cursorVisible="false"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Age -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Age (in years)"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etAge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Auto-filled from date of birth"
            android:inputType="number" />

        <!-- Age Group -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Age Group"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerAgeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="A: 1-4 yo   B: 5-14 yo   C: 15-19 yo   D: 20-59 yo   E: 60 yo and above"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray" />

        <!-- Sex -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sex"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgSex"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbMale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="M - Male" />

            <RadioButton
                android:id="@+id/rbFemale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="F - Female" />
        </RadioGroup>

        <!-- Risk & Screening -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="#EEEEEE"
            android:padding="8dp"
            android:text="Risk &amp; Screening"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="With history of travel to / exposure to a Schistosomiasis endemic area?" />

        <RadioGroup
            android:id="@+id/rgHistoryOfExposure"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbExposureYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Yes" />

            <RadioButton
                android:id="@+id/rbExposureNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - No" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Screened for Schistosomiasis?" />

        <RadioGroup
            android:id="@+id/rgScreened"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbScreenedYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Yes" />

            <RadioButton
                android:id="@+id/rbScreenedNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - No" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDateScreened"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Date Screened (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDateScreened"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Suspected / Clinical Cases -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="#EEEEEE"
            android:padding="8dp"
            android:text="Suspected / Clinical Cases"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="With signs and symptoms?" />

        <RadioGroup
            android:id="@+id/rgSignsSymptoms"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbSignsSymptomsYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Yes" />

            <RadioButton
                android:id="@+id/rbSignsSymptomsNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - No" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:text="If yes, select sign(s)/symptom(s):"
            android:textSize="12sp"
            android:textColor="@android:color/darker_gray" />

        <CheckBox
            android:id="@+id/cbSymptomAbdominalPain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A - Abdominal pain" />

        <CheckBox
            android:id="@+id/cbSymptomDiarrhea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="B - Diarrhea" />

        <CheckBox
            android:id="@+id/cbSymptomBloodInStool"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="C - Blood in the stool" />

        <CheckBox
            android:id="@+id/cbSymptomOthers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="D - Others" />

        <EditText
            android:id="@+id/etSymptomOthersSpecify"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Specify other sign/symptom"
            android:inputType="text" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clinical/Suspected Cases Treated (1st treatment)?" />

        <RadioGroup
            android:id="@+id/rgClinicalFirstTreatment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbClinicalFirstTreatmentYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Yes" />

            <RadioButton
                android:id="@+id/rbClinicalFirstTreatmentNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - No" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilClinicalFirstTreatmentDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Date 1st treatment started (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etClinicalFirstTreatmentDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Retreatment?" />

        <RadioGroup
            android:id="@+id/rgClinicalRetreatment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbClinicalRetreatmentYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Yes" />

            <RadioButton
                android:id="@+id/rbClinicalRetreatmentNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - No" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilClinicalRetreatmentDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Retreatment date (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etClinicalRetreatmentDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clinical/Suspected Cases Cured?" />

        <RadioGroup
            android:id="@+id/rgClinicalCured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbClinicalCuredYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Yes" />

            <RadioButton
                android:id="@+id/rbClinicalCuredNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - No" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilClinicalCuredDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Date cured (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etClinicalCuredDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Confirmed Schistosomiasis Case -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="#EEEEEE"
            android:padding="8dp"
            android:text="Confirmed Schistosomiasis Case"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Diagnostic Test (Kato-Katz / Kato Thick / Rectal Biopsy)" />

        <EditText
            android:id="@+id/etDiagnosticTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:hint="Enter test used"
            android:inputType="text" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDateOfDiagnosis"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Date of Diagnosis (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDateOfDiagnosis"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Result of Diagnostic Test" />

        <RadioGroup
            android:id="@+id/rgDiagnosticResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbDiagnosticPositive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Positive" />

            <RadioButton
                android:id="@+id/rbDiagnosticNegative"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - Negative" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDateConfirmed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Date Confirmed (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDateConfirmed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirmed Complicated / Non-Complicated" />

        <RadioGroup
            android:id="@+id/rgComplicated"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbComplicatedYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Complicated" />

            <RadioButton
                android:id="@+id/rbComplicatedNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - Non-Complicated" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirmed Cases Treated (1st treatment)?" />

        <RadioGroup
            android:id="@+id/rgConfirmedFirstTreatment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbConfirmedFirstTreatmentYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Yes" />

            <RadioButton
                android:id="@+id/rbConfirmedFirstTreatmentNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - No" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilConfirmedFirstTreatmentDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Date 1st treatment started (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etConfirmedFirstTreatmentDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Retreatment?" />

        <RadioGroup
            android:id="@+id/rgConfirmedRetreatment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbConfirmedRetreatmentYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Yes" />

            <RadioButton
                android:id="@+id/rbConfirmedRetreatmentNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - No" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilConfirmedRetreatmentDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Retreatment date (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etConfirmedRetreatmentDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Confirmed Cases Cured?" />

        <RadioGroup
            android:id="@+id/rgConfirmedCured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbConfirmedCuredYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Yes" />

            <RadioButton
                android:id="@+id/rbConfirmedCuredNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - No" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilConfirmedCuredDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Date confirmed cases cured (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etConfirmedCuredDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Hospital Referral -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="#EEEEEE"
            android:padding="8dp"
            android:text="Hospital Referral"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDateReferredToHospital"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Date Referred to Hospital (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDateReferredToHospital"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Schistosomiasis MDA -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="#EEEEEE"
            android:padding="8dp"
            android:text="Schistosomiasis MDA"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Given 1 dose of Praziquantel during MDA?" />

        <RadioGroup
            android:id="@+id/rgMdaGiven"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbMdaGivenYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="1 - Yes" />

            <RadioButton
                android:id="@+id/rbMdaGivenNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 - No" />
        </RadioGroup>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilMdaDateGiven"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Date given (yyyy-MM-dd)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etMdaDateGiven"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Remarks -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remarks"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etRemarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Enter any additional remarks"
            android:inputType="textMultiLine"
            android:minLines="2" />

        <!-- Actions -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Record" />

    </LinearLayout>
</ScrollView>