                    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:hint="Date Given (d)" android:layout_marginStart="4dp"><com.google.android.material.textfield.TextInputEditText android:id="@+id/etCcV4Date" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="date"/></com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

                <CheckBox
                    android:id="@+id/cbCompletedCc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Completed CC supplementation?"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Date Completed (d)">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etCcCompletedDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="date"/>
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveSupplementationForm"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Save Supplementation"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#0EA5E9"
            app:cornerRadius="8dp" />

    </LinearLayout>
</ScrollView>