<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8F9FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvFormTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Filariasis Registry"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:gravity="center" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDateOfRegistration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Date of Registration (YYYY-MM-DD)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDateOfRegistration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Family Serial Number"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <EditText
            android:id="@+id/etFamilySerialNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Enter Family Serial Number"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:cursorVisible="false"
            android:inputType="text" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Name (LastName, FullName, MI)"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

            <AutoCompleteTextView
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName" />

        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Address"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <EditText
            android:id="@+id/etAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Enter Address"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:clickable="false"
            android:cursorVisible="false"
            android:inputType="textPostalAddress" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDateOfBirth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Date of Birth (YYYY-MM-DD)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDateOfBirth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Age"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <EditText
            android:id="@+id/etAge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:focusable="false"
            android:longClickable="false"
            android:cursorVisible="false"
            android:hint="Calculated automatically"
            android:inputType="number" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Age Group"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <Spinner
            android:id="@+id/spinnerAgeGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sex"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <RadioGroup
            android:id="@+id/rgSex"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/rbMale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Male" />
            <RadioButton
                android:id="@+id/rbFemale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Female" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NBE / RDT Performed"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <CheckBox
            android:id="@+id/cbNbePerformed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NBE Performed" />
        <CheckBox
            android:id="@+id/cbRdtPerformed"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="RDT Performed" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDateNbeRdt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Date NBE / RDT (YYYY-MM-DD)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDateNbeRdt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Blood Test Result"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <RadioGroup
            android:id="@+id/rgBloodTestResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/rbResultPositive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Positive (+)" />
            <RadioButton
                android:id="@+id/rbResultNegative"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Negative (-)" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lymphedema Clinical Status"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <RadioGroup
            android:id="@+id/rgLymphedemaExamined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/rbLymphedemaExaminedYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Examined 1st Time" />
            <RadioButton
                android:id="@+id/rbLymphedemaExaminedNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not Examined" />
        </RadioGroup>
        <CheckBox
            android:id="@+id/cbLymphedemaPresent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Lymphedema Present" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Elephantiasis Clinical Status"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <RadioGroup
            android:id="@+id/rgElephantiasisExamined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/rbElephantiasisExaminedYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Examined 1st Time" />
            <RadioButton
                android:id="@+id/rbElephantiasisExaminedNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not Examined" />
        </RadioGroup>
        <CheckBox
            android:id="@+id/cbElephantiasisPresent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Elephantiasis Present" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hydrocele Clinical Status"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <RadioGroup
            android:id="@+id/rgHydroceleExamined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:orientation="horizontal">
            <RadioButton
                android:id="@+id/rbHydroceleExaminedYes"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                android:text="Examined 1st Time" />
            <RadioButton
                android:id="@+id/rbHydroceleExaminedNo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Not Examined" />
        </RadioGroup>
        <CheckBox
            android:id="@+id/cbHydrocelePresent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Hydrocele Present" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAlbendazoleDateGiven"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Albendazole — Date Given (YYYY-MM-DD)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etAlbendazoleDateGiven"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDecDateGiven"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="DEC — Date Given (YYYY-MM-DD)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDecDateGiven"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilIvermectinDateGiven"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Ivermectin — Date Given (YYYY-MM-DD)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etIvermectinDateGiven"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remarks"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />
        <EditText
            android:id="@+id/etRemarks"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:hint="Enter any additional remarks"
            android:inputType="textMultiLine"
            android:minLines="2" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Save Record"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="8dp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>