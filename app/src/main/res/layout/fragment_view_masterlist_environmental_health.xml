<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- Header Section -->
    <LinearLayout
        android:id="@+id/llHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A237E"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Environmental Health &amp; Sanitation"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvRecordCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Records: 0"
            android:textColor="#E0E0E0"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Search Bar Wrapper Container -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cvSearchContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/llHeader"
        android:layout_margin="12dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="3dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="12dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#757575" />

            <!-- Reusing standard dashboard ID etSearchOralRecords as bound in Java fragment -->
            <EditText
                android:id="@+id/etSearchOralRecords"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@android:color/transparent"
                android:hint="Search by Household Head Name..."
                android:textColor="#212121"
                android:textColorHint="#757575"
                android:textSize="15sp"
                android:imeOptions="actionSearch"
                android:inputType="textPersonName"
                android:paddingHorizontal="10dp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Empty State View -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="No environmental health records found."
        android:textColor="#757575"
        android:textSize="16sp"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- Core RecyclerView Masterlist Dashboard (Bound to ID: rvOralRecords) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvOralRecords"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/cvSearchContainer"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        tools:listitem="@layout/item_environmental_health_record" />

    <!-- Action Action Trigger: Floating Action Button (Bound to ID: fabAddOralRecord) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddOralRecord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp"
        android:contentDescription="Add Environmental Health Entry"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#1A237E"
        app:tint="#FFFFFF" />

</RelativeLayout>