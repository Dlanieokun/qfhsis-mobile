<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvFormTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Target Client List for Geriatric Screening and Senior Citizen Immunization"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Administrative &amp; Client Details"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDateOfScreening"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:hint="Date of Screening (YYYY-MM-DD)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDateOfScreening"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Family Serial Number">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etFamilySerialNumber"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:clickable="false"
                android:cursorVisible="false"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Full Name (Last, First, M.I.)">
            <AutoCompleteTextView
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Complete Address">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:clickable="false"
                android:cursorVisible="false"
                android:inputType="textPostalAddress" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDateOfBirth"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Date of Birth (YYYY-MM-DD)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etDateOfBirth"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:clickable="false"
                android:cursorVisible="false"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="Age (In Years)">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAge"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number" />
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Sex"
            android:textAppearance="?attr/textAppearanceBodyMedium" />

        <RadioGroup
            android:id="@+id/rgSex"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="horizontal">

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rbMale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:text="Male (M)" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/rbFemale"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Female (F)" />
        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Screening Domain Assessments (Select all that apply)"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Material3.CardView.Outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:contentPadding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <CheckBox
                    android:id="@+id/cbResultNegative"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="0 - Negative Screening Result" />

                <CheckBox
                    android:id="@+id/cbResultMemory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="A - Memory Loss / Cognitive Impairment" />

                <CheckBox
                    android:id="@+id/cbResultDepression"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="B - Depression / Mood Fluctuations" />

                <CheckBox
                    android:id="@+id/cbResultPolypharmacy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="C - Polypharmacy Risk" />

                <CheckBox
                    android:id="@+id/cbResultUrinary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="D - Urinary Incontinence Problems" />

                <CheckBox
                    android:id="@+id/cbResultFunctional"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="E - Functional Capacity Limitations" />

                <CheckBox
                    android:id="@+id/cbResultFall"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="F - Fall Risk History / Complications" />

                <CheckBox
                    android:id="@+id/cbResultMalnutrition"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="G - Malnutrition Tracking Vulnerability" />

                <CheckBox
                    android:id="@+id/cbResultHearing"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="H - Hearing Deficit / Impairment" />

                <CheckBox
                    android:id="@+id/cbResultVision"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="I - Vision Loss / Ocular Deficit" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Interventions &amp; Senior Citizen Immunizations"
            android:textAppearance="?attr/textAppearanceLabelLarge"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchCarePlanProvided"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="Provided with Care Plan / Referred (1=Yes / 0=No)" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switchPpvReceived"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="Received PPV at age 60 (1=Yes / 0=No)" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilPpvDateGiven"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="PPV Date Given (YYYY-MM-DD)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etPpvDateGiven"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilInfluenzaDateGiven"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Influenza Date Given (YYYY-MM-DD)"
            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
            <EditText
                android:id="@+id/etInfluenzaDateGiven"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="date"
                android:maxLength="10" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="Remarks / Additional Observations">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etRemarks"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:minLines="2" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Record"
            android:textAppearance="?attr/textAppearanceButton" />

    </LinearLayout>
</ScrollView>