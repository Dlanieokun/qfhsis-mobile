<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".child.ChildCareServicesFragment">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        android:text="Child Care Services"
        android:textSize="24sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnChildImmunization"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:text="Child Immunization"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnChildImmunizationSchool"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:text="Child Immunization School"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnChildNutrition"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:text="Child Nutrition"
        android:textSize="16sp" />

    <Button
        android:id="@+id/btnManagementOfSick"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:text="Management of Sick"
        android:textSize="16sp" />

</LinearLayout>