<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable row for one month's antihypertensive medication recording.
    Set the month label programmatically via tvMonthLabel.setText(month).
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#EEF2FF"
    android:padding="8dp">

    <!-- Month label -->
    <TextView
        android:id="@+id/tvMonthLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Month"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="#1565C0"
        android:paddingBottom="4dp"/>

    <!-- PBF / OOP / Both row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- PBF -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="PBF (# tablets)" android:textSize="11sp" android:textColor="#444444"/>
            <EditText android:id="@+id/etPBF"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="#" android:inputType="number" android:maxLines="1"/>
        </LinearLayout>

        <!-- OOP -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="4dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="OOP (# tablets)" android:textSize="11sp" android:textColor="#444444"/>
            <EditText android:id="@+id/etOOP"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="#" android:inputType="number" android:maxLines="1"/>
        </LinearLayout>

        <!-- Both checkbox -->
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical"
            android:gravity="center_horizontal">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Both" android:textSize="11sp" android:textColor="#444444"
                android:gravity="center"/>
            <CheckBox android:id="@+id/cbBoth"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"/>
        </LinearLayout>

    </LinearLayout>
</LinearLayout>