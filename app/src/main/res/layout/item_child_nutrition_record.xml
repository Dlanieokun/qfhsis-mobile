<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="8dp"
    app:cardElevation="3dp"
    app:strokeColor="#E0E0E0"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvItemChildName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="JUAN DELA CRUZ"
            android:textColor="#1565C0"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/tvItemSex"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvItemSex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:background="#E3F2FD"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Sex: M"
            android:textColor="#0D47A1"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvItemChildName"
            app:layout_constraintEnd_toStartOf="@+id/tvItemAgeMonths"
            app:layout_constraintTop_toTopOf="@id/tvItemChildName" />

        <TextView
            android:id="@+id/tvItemAgeMonths"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#E8F5E9"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="Age: 14 mos."
            android:textColor="#1B5E20"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/tvItemChildName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvItemChildName" />

        <View
            android:id="@+id/vItemDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:background="#F5F5F5"
            app:layout_constraintTop_toBottomOf="@id/tvItemChildName" />

        <TextView
            android:id="@+id/tvItemSerial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Serial No: FAM-2026-0042"
            android:textColor="#424242"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@+id/btnItemEdit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/vItemDivider" />

        <TextView
            android:id="@+id/tvItemRegDate"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Registered: 2026-03-15"
            android:textColor="#616161"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@+id/btnItemEdit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvItemSerial" />

        <TextView
            android:id="@+id/tvItemAddress"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Address: Barangay 5A, Tacloban City"
            android:textColor="#616161"
            android:textSize="13sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintEnd_toStartOf="@+id/btnItemEdit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvItemRegDate" />

        <TextView
            android:id="@+id/tvItemStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#FFF3E0"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Normal Wt."
            android:textColor="#E65100"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvItemAddress" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnItemEdit"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EDIT"
            android:textColor="#1565C0"
            android:textSize="14sp"
            android:textStyle="bold"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconTint="#1565C0"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/vItemDivider" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>