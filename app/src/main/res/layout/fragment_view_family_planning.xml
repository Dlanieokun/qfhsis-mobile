<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <!-- MAIN CONTENT CONTAINER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="16dp">

        <!-- SEARCH FILTER BAR (TOP) -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:hint="Search by client name..."
            app:startIconDrawable="@android:drawable/ic_menu_search"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearchFP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Header Counter Panel Row[cite: 8] -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTotalRecordsCount"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Total Saved Records: 0"
                android:textColor="#1F2937"
                android:textSize="18sp"
                android:textStyle="bold" />[cite: 8]
        </LinearLayout>

        <!-- Content Frame[cite: 8] -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Fallback Content Frame Context Box Container[cite: 8] -->
            <LinearLayout
                android:id="@+id/layoutEmptyState"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">[cite: 8]

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No Family Planning Records Found"
                    android:textColor="#4B5563"
                    android:textSize="16sp"
                    android:textStyle="bold"/>[cite: 8]

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saved records will appear here automatically."
                    android:textColor="#9CA3AF"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp"
                    android:gravity="center"/>[cite: 8]
            </LinearLayout>

            <!-- Active List Layout Wrapper Scroller Frame[cite: 8] -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFamilyPlanning"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scrollbars="vertical"/>[cite: 8]
        </FrameLayout>
    </LinearLayout>

    <!-- ADD RECORD FLOATING ACTION BUTTON (BOTTOM RIGHT) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddFP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_margin="24dp"
        android:contentDescription="Add Family Planning Record"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#2563EB"
        app:tint="#FFFFFF" />

</RelativeLayout>