<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:id="@+id/llSearchHeaderContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FFFFFF"
        android:padding="16dp"
        android:elevation="4dp"
        android:translationZ="2dp">

        <TextView
            android:id="@+id/tvRegistryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Filariasis Registry Workspace"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#212121"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etSearchEyesRecords"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@android:drawable/editbox_background_normal"
            android:hint="Search by name or family serial number..."
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textCursorDrawable="@null"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tvEyesRecordCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Total Records: 0"
            android:textSize="13sp"
            android:textColor="#666666"
            android:textStyle="italic"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvEyesRecords"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/llSearchHeaderContainer"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="88dp"
        android:scrollbars="vertical" />

    <TextView
        android:id="@+id/tvEyesEmptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="No filariasis records found"
        android:textColor="#9E9E9E"
        android:textSize="16sp"
        android:textStyle="italic"
        android:visibility="gone" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddEyesRecord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Add New Entry"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#008577"
        app:fabSize="normal"
        app:tint="#FFFFFF" />

</RelativeLayout>